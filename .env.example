# local: ./run-local.sh
# docker deploy: docker compose up -d --build app
# prod: 운영 seed 구성, dev: demo 유저/거래/지갑 seed 포함
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# In prod, replace this with a random value of at least 32 chars.
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_SECRET
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# Local defaults. The app service in docker-compose overrides service host names internally.
DB_URL=jdbc:mariadb://localhost:3306/finvibe
DB_USERNAME=finvibe
DB_PASSWORD=finvibe123
REDIS_HOST=localhost
REDIS_PORT=6379
MONGODB_URI=mongodb://root:root1234@localhost:27017/finvibe?authSource=admin
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
FINVIBE_DATA_DIR=./runtime

# Add deployed frontend domains here, comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

KIS_ENABLED=true
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=YOUR_KIS_APP_KEY
KIS_APP_SECRET=YOUR_KIS_APP_SECRET
KIS_TIMEOUT_MS=5000

GEMINI_ENABLED=false
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=15000
